<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MyAvaloniaApp.Views.MainWindow"
        Width="900"
        Height="560"
        Title="IDA Görüntü İşleme Test Arayüzü"
        Background="#0F172A">

    <Grid Margin="16"
          ColumnDefinitions="*,340"
          RowDefinitions="Auto,*"
          ColumnSpacing="16"
          RowSpacing="12">

        <StackPanel Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    Spacing="10">

            <Button Content="TCP Server Başlat"
                    Click="StartButton_Click"
                    Padding="14,8"/>

            <Button Content="Temizle"
                    Click="ClearButton_Click"
                    Padding="14,8"/>

            <TextBlock x:Name="StatusText"
                       Text="Bekleniyor..."
                       Foreground="White"
                       VerticalAlignment="Center"
                       FontSize="16"/>
        </StackPanel>

        <Border Grid.Row="1"
                Grid.Column="0"
                Background="#111827"
                BorderBrush="#334155"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">

            <Grid RowDefinitions="Auto,*">
                <TextBlock Text="Gelen TCP Verisi"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <TextBox x:Name="LogBox"
                         Grid.Row="1"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         FontSize="14"
                         Foreground="White"
                         Background="#020617"
                         BorderThickness="0"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1"
                    Grid.Column="1"
                    Spacing="10">

            <TextBlock Text="Mini Engel Haritası"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"/>

            <TextBlock Text="Engeller, tahmini mesafe ve sağ/sol konuma göre çizilir."
                       Foreground="#CBD5E1"
                       TextWrapping="Wrap"
                       FontSize="13"/>

            <Border Width="320"
                    Height="320"
                    Background="#020617"
                    BorderBrush="#475569"
                    BorderThickness="2"
                    CornerRadius="8">

                <Grid>
                    <TextBlock Text="ÜSTTEN BAKIŞ"
                               Foreground="#1E293B"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="20"
                               FontWeight="Bold"/>

                    <Canvas x:Name="VisionCanvas"
                            Width="320"
                            Height="320"/>
                </Grid>
            </Border>

            <TextBlock Text="Altta İDA, yukarı doğru kamera önü kabul edilir."
                       Foreground="#94A3B8"
                       TextWrapping="Wrap"
                       FontSize="12"/>
        </StackPanel>

    </Grid>
</Window>